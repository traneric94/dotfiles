# Generated by scripts/gen-skhdrc.sh — do not edit directly.
# To change bindings, edit apps.json and re-run install.sh.
rshift - s : if pgrep "Slack" > /dev/null; then osascript -e 'tell application "Slack" to activate'; else open -a "Slack"; fi
rshift - 1 : osascript -e 'tell application "Ghostty" to activate' -e 'delay 0.2' -e 'tell application "System Events" to tell process "Ghostty" to if (count of windows) = 0 then keystroke "n" using command down'
rshift - o : if pgrep "Spotify" > /dev/null; then osascript -e 'tell application "Spotify" to activate'; else open -a "Spotify"; fi
rshift - n : if pgrep "Notion" > /dev/null; then osascript -e 'tell application "Notion" to activate'; else open -a "Notion"; fi
rshift - z : if pgrep "zoom.us" > /dev/null; then osascript -e 'tell application "zoom.us" to activate'; else open -a "zoom.us"; fi
rshift - d : if pgrep "Discord" > /dev/null; then osascript -e 'tell application "Discord" to activate'; else open -a "Discord"; fi
rshift - p : if pgrep "1Password" > /dev/null; then osascript -e 'tell application "1Password" to activate'; else open -a "1Password"; fi
rshift - 2 : osascript -e 'tell application "Google Chrome" to activate' -e 'if (count of windows of application "Google Chrome") = 0 then tell application "Google Chrome" to make new window'
rshift - f : osascript -e 'tell application "Firefox" to reopen' -e 'tell application "Firefox" to activate'
rshift - r : if pgrep "Rectangle" > /dev/null; then osascript -e 'tell application "Rectangle" to activate'; else open -a "Rectangle"; fi
rshift - m : if pgrep "SDM" > /dev/null; then osascript -e 'tell application "SDM" to activate'; else open -a "SDM"; fi
