{
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "WebFetch(domain:*)",
      "mcp__atlassian__createJiraIssue",
      "mcp__atlassian__getAccessibleAtlassianResources",
      "mcp__atlassian__getJiraIssue",
      "mcp__atlassian__searchJiraIssuesUsingJql",
      "mcp__atlassian__atlassianUserInfo",
      "mcp__atlassian__lookupJiraAccountId",
      "mcp__atlassian__editJiraIssue",
      "mcp__atlassian__addCommentToJiraIssue",
      "mcp__atlassian__transitionJiraIssue",
      "mcp__atlassian__search",
      "mcp__notion__notion-search",
      "mcp__notion__notion-fetch",
      "mcp__notion__notion-update-page",
      "mcp__notion__notion-create-pages",
      "mcp__github__get_file_contents",
      "mcp__github__search_code",
      "mcp__github__search_repositories",
      "mcp__github__list_pull_requests",
      "mcp__github__pull_request_read",
      "mcp__github__list_issues",
      "mcp__github__issue_read",
      "mcp__github__list_commits",
      "mcp__github__get_commit",
      "mcp__github__get_me",
      "mcp__github__search_pull_requests",
      "mcp__github__search_issues",
      "mcp__github__issue_write",
      "mcp__github__create_branch",
      "mcp__github__create_pull_request",
      "mcp__github__update_pull_request",
      "mcp__github__push_files",
      "mcp__github__create_or_update_file",
      "mcp__github__add_issue_comment",
      "mcp__github__add_reply_to_pull_request_comment",
      "mcp__github__add_comment_to_pending_review",
      "mcp__github__pull_request_review_write",
      "mcp__github__list_branches",
      "mcp__github__list_tags",
      "mcp__github__get_latest_release",
      "mcp__github__merge_pull_request",
      "WebFetch(domain:circleci.com)",
      "WebFetch(domain:app.circleci.com)",
      "WebFetch(domain:code.claude.com)",
      "Skill(update-config)",
      "mcp__plugin_gigabrain_gigabrain__query",
      "mcp__plugin_gigabrain_gigabrain__status",
      "WebFetch(domain:chime.sourcegraph.com)",
      "mcp__atlassian__getConfluencePage",
      "mcp__atlassian__searchConfluenceUsingCql",
      "mcp__atlassian__createConfluencePage",
      "mcp__atlassian__updateConfluencePage",
      "mcp__atlassian__searchAtlassian",
      "mcp__atlassian__fetchAtlassian",
      "mcp__datadog-mcp__search_datadog_metrics",
      "mcp__datadog-mcp__get_datadog_metric_context",
      "mcp__atlassian__getConfluenceSpaces",
      "mcp__datadog-mcp__analyze_datadog_logs",
      "mcp__datadog-mcp__search_datadog_logs",
      "mcp__datadog-mcp__get_datadog_metric",
      "mcp__datadog-mcp__search_datadog_events",
      "mcp__glean__search",
      "mcp__datadog-mcp__search_datadog_monitors",
      "mcp__glean__read_document",
      "mcp__datadog-mcp__list_datadog_skills",
      "mcp__datadog-mcp__load_datadog_skill",
      "mcp__glean__chat",
      "mcp__claude_ai_Atlassian__editJiraIssue",
      "mcp__datadog-mcp__aggregate_spans",
      "mcp__claude_ai_Atlassian__getJiraIssue"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(sudo:*)",
      "Bash(chmod:*)",
      "Read(.env)",
      "Read(.env.local)",
      "Read(.env.*)",
      "Read(.envrc)"
    ],
    "ask": [],
    "defaultMode": "acceptEdits",
    "additionalDirectories": [
      "~/.config",
      "~/dotfiles",
      "/tmp"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/route.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/capture-corrections.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(jq -r '.tool_input.file_path // empty'); case \"$FILE\" in *.go) go fmt \"$FILE\" 2>/dev/null ;; *.rb) RBENV_ROOT=\"${RBENV_ROOT:-$HOME/.rbenv}\"; export PATH=\"$RBENV_ROOT/shims:$RBENV_ROOT/bin:$PATH\"; DIR=$(dirname \"$FILE\"); cd \"$DIR\" && while [ \"$PWD\" != \"/\" ] && [ ! -f Gemfile ]; do cd ..; done; [ -f Gemfile ] && bundle exec rubocop -a \"$FILE\" --no-color 2>/dev/null || true ;; *.ts|*.tsx) PROJ=$(realpath \"$FILE\"); while [ \"$PROJ\" != \"/\" ] && [ ! -f \"$PROJ/package.json\" ]; do PROJ=$(dirname \"$PROJ\"); done; [ -f \"$PROJ/package.json\" ] && cd \"$PROJ\" && yarn eslint --fix \"$FILE\" 2>/dev/null || true ;; esac"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/notify-stop.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "TMUX_WIN=$([ -n \"$TMUX\" ] && tmux display-message -p '#S' 2>/dev/null || echo \"\"); TITLE=$([ -n \"$TMUX_WIN\" ] && echo \"Terminal:$TMUX_WIN\" || echo \"Terminal\"); terminal-notifier -title \"$TITLE\" -message \"Approval needed\" -sound Basso 2>/dev/null || afplay /System/Library/Sounds/Basso.aiff"
          }
        ]
      },
      {
        "matcher": "elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "TMUX_WIN=$([ -n \"$TMUX\" ] && tmux display-message -p '#S' 2>/dev/null || echo \"\"); TITLE=$([ -n \"$TMUX_WIN\" ] && echo \"Terminal:$TMUX_WIN\" || echo \"Terminal\"); terminal-notifier -title \"$TITLE\" -message \"Needs clarification\" -sound Basso 2>/dev/null || afplay /System/Library/Sounds/Basso.aiff"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "TMUX_WIN=$([ -n \"$TMUX\" ] && tmux display-message -p '#S' 2>/dev/null || echo \"\"); TITLE=$([ -n \"$TMUX_WIN\" ] && echo \"Terminal:$TMUX_WIN\" || echo \"Terminal\"); terminal-notifier -title \"$TITLE\" -message \"Compacting context...\" -sound Purr 2>/dev/null || afplay /System/Library/Sounds/Purr.aiff"
          }
        ]
      }
    ]
  },
  "outputStyle": "default",
  "spinnerTipsEnabled": false
}
